# ──────────────────────────────────────────────────────────────────────────────
# SUS-Flow — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# Neon PostgreSQL — Pooled connection (Supavisor / PgBouncer, port 6543)
# Used by Prisma Client at runtime on Vercel serverless functions.
# Format: postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech:6543/neondb?sslmode=require
DATABASE_URL=

# Neon PostgreSQL — Direct connection (port 5432)
# Used ONLY by `prisma migrate dev` and `prisma db push` — never at runtime.
# Format: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech:5432/neondb?sslmode=require
DIRECT_URL=

# Google Generative AI key — required by Phase 5 (AI Classifier)
# Get yours at https://aistudio.google.com/app/apikey (free tier available)
GOOGLE_GENERATIVE_AI_API_KEY=

# Cron secret — random string verified by /api/cron/simulate as Authorization: Bearer header
CRON_SECRET=

# iron-session encryption secret — must be 32+ random characters
IRON_SESSION_SECRET=
